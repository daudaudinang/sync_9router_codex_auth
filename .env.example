# Local data dir containing db.json
DATA_DIR=$HOME/.9router

# Runner timing
CODEX_SYNC_INTERVAL_SEC=300
CODEX_SYNC_ACK_TIMEOUT_MS=5000
CODEX_SYNC_POLL_INTERVAL_MS=150

# Remote backend: file | s3 | minio
CODEX_SYNC_REMOTE_MODE=minio
CODEX_SYNC_OBJECT_KEY=inventory/codex-accounts.json

# File mode only
# CODEX_SYNC_REMOTE_FILE=/absolute/path/to/remote.json

# S3 / MinIO mode
CODEX_SYNC_S3_ENDPOINT=https://api-minio.littlepea.site
CODEX_SYNC_S3_BUCKET=uploads
CODEX_SYNC_S3_REGION=us-east-1
CODEX_SYNC_S3_ACCESS_KEY_ID=minioadmin
CODEX_SYNC_S3_SECRET_ACCESS_KEY=supersecret
CODEX_SYNC_S3_FORCE_PATH_STYLE=true
# CODEX_SYNC_S3_SESSION_TOKEN=

# Optional full-file encryption
# SYNC_SHARED_KEY=your-shared-key

# Dashboard
DASHBOARD_PORT=3001
DASHBOARD_ENABLED=true
